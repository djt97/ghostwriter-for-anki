{
  "name": "ghostwriter",
  "version": "0.3.3",
  "private": true,
  "scripts": {
    "build:release": "node scripts/build-release.js",
    "test": "node --test tests/unit/*.test.js",
    "lint": "eslint .",
    "test:ui": "playwright test -c playwright.config.ts --grep @screenshots",
    "test:install": "playwright install --with-deps chromium",
    "test:screenshots": "playwright test -c playwright.config.ts --grep @screenshots",
    "build:mathjax": "node ./node_modules/mathjax-full/components/bin/makeAll"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "eslint": "^9.39.4",
    "mathjax-full": "^3.2.1",
    "webpack": "^5.105.0",
    "webpack-cli": "^6.0.1"
  }
}
